  <script>
    // Drag-to-scroll for projects carousel
    (() => {
      const el = document.getElementById('projects-carousel');
      if (!el) return;

      let isDown = false;
      let startX: number;
      let scrollLeft: number;
      let dragged = false;

      el.addEventListener('mousedown', (e) => {
        isDown = true;
        dragged = false;
        el.classList.add('cursor-grabbing');
        el.classList.remove('cursor-grab');
        el.style.scrollBehavior = 'auto';
        el.style.scrollSnapType = 'none';
        startX = e.pageX - el.offsetLeft;
        scrollLeft = el.scrollLeft;
      });

      el.addEventListener('mouseleave', () => {
        isDown = false;
        el.classList.remove('cursor-grabbing');
        el.classList.add('cursor-grab');
        el.style.scrollSnapType = '';
      });

      el.addEventListener('mouseup', () => {
        isDown = false;
        el.classList.remove('cursor-grabbing');
        el.classList.add('cursor-grab');
        el.style.scrollSnapType = '';
      });

      el.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - el.offsetLeft;
        const walk = (x - startX) * 1.5;
        if (Math.abs(walk) > 5) dragged = true;
        el.scrollLeft = scrollLeft - walk;
      });

      // Prevent click on links if user was dragging
      el.addEventListener('click', (e) => {
        if (dragged) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);
    })();
  </script>

  <script>
    import Masonry from 'masonry-layout';

    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.getElementById('masonry-grid');
      if (!grid) return;

      const msnry = new Masonry(grid, {
        itemSelector: '.masonry-item',
        columnWidth: '.masonry-item:not(.masonry-item--wide)',
        percentPosition: true,
        gutter: 24,
      });

      // Re-layout after iframes and images load
      const iframes = grid.querySelectorAll('iframe');
      iframes.forEach((iframe) => {
        iframe.addEventListener('load', () => msnry.layout());
      });

      const images = grid.querySelectorAll('img');
      images.forEach((img) => {
        if (img.complete) return;
        img.addEventListener('load', () => msnry.layout());
      });
    });
