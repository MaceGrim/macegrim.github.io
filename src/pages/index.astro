---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Sorted by date descending. Lakota AI Code Camp (portfolio-3) should always be first —
// give it the newest date to keep it at the top.
const projects = (await getCollection('portfolio')).sort(
  (a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime()
);
---

<BaseLayout title="Mason Grimshaw | AI Engineer, Educator, Builder">
  <!-- Hero Section -->
  <section class="relative bg-navy text-cream py-24 sm:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
        <div class="flex-shrink-0">
          <img
            src="/images/profile.png"
            alt="Mason Grimshaw"
            class="w-full max-w-[280px] rounded-xl object-cover shadow-lg"
          />
        </div>
        <div class="text-center md:text-left">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
            Mason Grimshaw
          </h1>
          <p class="text-lg sm:text-xl text-cream/80 leading-relaxed mb-6">
            AI Engineer at <a href="https://ode.partners" class="text-burnt-orange hover:underline">Ode Partners</a>.
            VP of <a href="https://www.indigi-genius.com" class="text-burnt-orange hover:underline">IndigiGenius</a>.
            Co-founder of the <a href="https://lakota.aicode.camp" class="text-burnt-orange hover:underline">Lakota AI Code Camp</a>.
            Sicangu Lakota. Husband. Dad to 4.
          </p>
          <p class="text-lg text-cream/60 leading-relaxed">
            I build AI tools for organizations and tribal nations, teach data science to Indigenous youth and practitioners, and have advised on AI policy at the federal level.
            Most of my time goes to figuring out what a tool actually does for people
            — and whether it should exist at all.
          </p>
        </div>
      </div>
    </div>
    <!-- Decorative accent -->
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-burnt-orange"></div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 sm:py-24 bg-cream-dark overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mb-10">
      <div class="max-w-3xl">
        <p class="text-burnt-orange font-semibold text-sm uppercase tracking-widest mb-4">Projects</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4">
          Things I've helped build.
        </h2>
        <p class="text-lg text-navy/70 leading-relaxed">
          A mix of production tools, community platforms, and experiments.
        </p>
      </div>
    </div>

    <div
      id="projects-carousel"
      class="flex gap-6 overflow-x-auto snap-x snap-proximity pb-6 cursor-grab"
      style="scrollbar-width: thin; scrollbar-color: #CC5500 transparent; -webkit-overflow-scrolling: touch;"
    >
      <div class="shrink-0 w-4 sm:w-6 lg:w-8" aria-hidden="true"></div>
      {projects.map((project) => (
        <div class="snap-start shrink-0 w-[340px] sm:w-[400px] bg-white rounded-xl shadow-sm border border-cream-dark transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg hover:border-burnt-orange/30 flex flex-col overflow-hidden">
          {project.data.image ? (
            project.data.image_fit === 'contain' ? (
              <div class="h-48 overflow-hidden bg-white flex items-center justify-center p-4">
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="max-w-full max-h-full object-contain"
                />
              </div>
            ) : (
              <div class="h-48 overflow-hidden">
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full h-full object-cover"
                />
              </div>
            )
          ) : (
            <div class="h-3 bg-burnt-orange/20"></div>
          )}
          <div class="p-8 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-navy mb-2">{project.data.title}</h3>
            <p class="text-navy/60 leading-relaxed mb-6 flex-1">{project.data.description}</p>
            <div class="flex gap-3">
              {project.data.demo_url && (
                <a
                  href={project.data.demo_url}
                  class="px-4 py-2 border-2 border-burnt-orange text-burnt-orange text-sm font-semibold rounded-md hover:bg-burnt-orange hover:text-cream transition-colors"
                >
                  View Project
                </a>
              )}
              {project.data.source_url && (
                <a
                  href={project.data.source_url}
                  class="px-4 py-2 border-2 border-navy/20 text-navy/60 text-sm font-semibold rounded-md hover:border-navy/40 hover:text-navy transition-colors"
                >
                  Source
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
