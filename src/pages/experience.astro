---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Experience | Mason Grimshaw">
  <!-- Header -->
  <section class="relative bg-navy text-cream py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-burnt-orange font-semibold text-sm uppercase tracking-widest mb-4">Background</p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-6">Experience</h1>
      <p class="text-lg text-cream/70 leading-relaxed max-w-2xl">
        I went to MIT, grew up on the Rosebud Reservation, and have spent the last eight years turning data into tools that actually help people, from optimizing transit routes in Boston to teaching AI to Lakota youth.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-burnt-orange"></div>
  </section>

  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Education -->
      <h2 class="text-2xl font-bold text-navy mb-6">Education</h2>
      <div class="space-y-6 mb-16 border-l-2 border-burnt-orange/20 pl-6 ml-3">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">MIT Sloan School of Management</h3>
              <p class="text-burnt-orange font-medium mt-1">Master of Business Analytics</p>
              <p class="text-navy/60 mt-1">Operations Research Center</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Dean's Fellowship Recipient: Awarded for outstanding academic records, personal achievements, and professional promise.</li>
                <li>Coursework: Machine Learning, Optimization Methods, Statistics, Interactive Data Visualization</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Aug 2018 &ndash; Aug 2019</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">Massachusetts Institute of Technology</h3>
              <p class="text-burnt-orange font-medium mt-1">Bachelor of Business Analytics</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Coursework: Artificial Intelligence, Software Construction, Laboratory in Investments, Stochastic Models, Discrete Mathematics, Communicating with Data, Computation Structures</li>
                <li>MIT Chapter of Sigma Nu (Governance Chair, Vice President, Community Service Chairman): Improved chapter performance in 9/10 areas; tripled total community service hours</li>
                <li>MIT American Indian Science and Engineering Society (Vice President): Facilitated outreach to American Indian freshmen and high school students; coordinated with campus organizations for the Native American community</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Aug 2014 &ndash; Jun 2018</span>
          </div>
        </div>
      </div>

      <!-- Work Experience -->
      <h2 class="text-2xl font-bold text-navy mb-6">Work Experience</h2>
      <div class="space-y-6 border-l-2 border-burnt-orange/20 pl-6 ml-3">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">Ode Partners</h3>
              <p class="text-burnt-orange font-medium mt-1">Partner, Data Science</p>
              <p class="text-navy/60 mt-1">Remote (Rapid City, SD)</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Creating digital products and solutions for environmental impact.</li>
                <li>"Full Stack" Data Scientist: Sourcing, Joining, Preparing, Visualizing, and Modeling Data.</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Jul 2023 &ndash; Present</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">IndigiGenius</h3>
              <p class="text-burnt-orange font-medium mt-1">Vice President</p>
              <p class="text-navy/60 mt-1">Remote (Rapid City, SD)</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Building and delivering the "Introduction to Python and Data Science" curriculum for the Lakota AI Code Camp.</li>
                <li>Organizing and MCing the Indigenous in AI Workshops for NeurIPS.</li>
                <li>Engaging in thought leadership with a focus on increasing Indigenous participation and perspectives in AI/ML (most recently at TEDx Boston: Countdown to AGI).</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Apr 2021 &ndash; Present</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">The Earth Genome</h3>
              <p class="text-burnt-orange font-medium mt-1">Data Science, Product</p>
              <p class="text-navy/60 mt-1">Remote (Rapid City, SD)</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Delivering value through linear optimization, data processing, and advanced cartographical techniques.</li>
                <li>Designing community-driven solutions by demonstrating the art-of-the-possible and implementing alongside the engineering team.</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Jul 2022 &ndash; Jul 2023</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">MFS Investment Management</h3>
              <p class="text-burnt-orange font-medium mt-1">Senior Data Science Analyst</p>
              <p class="text-navy/60 mt-1">Boston, MA</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Worked with cross-functional stakeholders and senior leaders to gather and synthesize data while performing analysis and delivering recommendations.</li>
                <li>Built models to describe the past and suggest optimal actions for salespeople.</li>
                <li>Furthering the data-driven culture of MFS by demonstrating proof of concepts for new analytics ideas.</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Oct 2019 &ndash; Jul 2022</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">MIT Sloan / MBTA</h3>
              <p class="text-burnt-orange font-medium mt-1">Data Science Intern</p>
              <p class="text-navy/60 mt-1">Boston, MA</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Optimized garage placement to minimize dead-head for drivers with an estimated 3-5% improvement and $3M-$5M in total yearly savings.</li>
                <li>Predicted trip cancellations to better understand realized, daily trip demand.</li>
                <li>Combined linear programming, optimization, and machine learning for near-instant rerouting of The RIDE system.</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Feb 2019 &ndash; Aug 2019</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">MIT Crypto-Economics Lab</h3>
              <p class="text-burnt-orange font-medium mt-1">Research Assistant</p>
              <p class="text-navy/60 mt-1">Cambridge, MA</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Applied natural language processing algorithms (Topic Modeling, Sentiment Analysis) to massive amounts of text data.</li>
                <li>Wrote scraping software (Python) to improve and expand the data pipeline.</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Sep 2017 &ndash; Jan 2019</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h3 class="text-xl font-bold text-navy">Intel Corporation, Intel Federal</h3>
              <p class="text-burnt-orange font-medium mt-1">Systems Architecture Team &ndash; Graduate Technical Intern</p>
              <p class="text-navy/60 mt-1">Hudson, MA</p>
              <ul class="mt-3 space-y-1 text-navy/60 text-sm">
                <li>Created a simulation for High Performance Linpack on cutting-edge computer systems to inform design decisions for new architectures.</li>
                <li>Performed workload analysis on biologically inspired computing paradigms and presented recommendations to the senior architect.</li>
              </ul>
            </div>
            <span class="text-sm text-navy/50 whitespace-nowrap">Summer 2018</span>
          </div>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-navy/10">
        <a href="/" class="text-burnt-orange hover:underline font-medium">&larr; Back to Home</a>
      </div>
    </div>
  </section>
</BaseLayout>
